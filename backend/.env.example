# Conexion a PostgreSQL. Cuando se corre con docker-compose el host es "db".
# Para correr el backend fuera de docker, sustituir por localhost.
DATABASE_URL=postgresql+psycopg2://wallet_user:wallet_pass@localhost:5432/wallet

# JWT
JWT_SECRET_KEY=cambia-esto-por-una-cadena-larga-aleatoria
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=60

# Cifrado de datos sensibles
FERNET_KEY=reemplazar-por-llave-fernet-base64
FINGERPRINT_PEPPER=cambia-esto-por-una-cadena-aleatoria

# CORS
CORS_ORIGINS=http://localhost:5173

# Entorno (development, testing, production)
APP_ENV=development
