# Configuracion de la base de datos PostgreSQL
POSTGRES_USER=wallet_user
POSTGRES_PASSWORD=wallet_pass
POSTGRES_DB=wallet
POSTGRES_PORT=5432

# Configuracion del backend
APP_ENV=development
JWT_SECRET_KEY=cambia-esto-por-una-cadena-larga-aleatoria
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=60

# Llave Fernet para cifrar datos sensibles del metodo de pago.
# Generar con: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
FERNET_KEY=reemplazar-por-llave-fernet-base64

# Pimienta usada en el fingerprint (SHA-256 con HMAC) para detectar duplicados
# sin desencriptar. Debe ser una cadena estable por instalacion.
FINGERPRINT_PEPPER=cambia-esto-por-una-cadena-aleatoria

# Origenes permitidos para CORS, separados por coma
CORS_ORIGINS=http://localhost:5173

# URL del backend que consume el frontend
VITE_API_URL=http://localhost:8000
